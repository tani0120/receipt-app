# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules

# Build output
dist
dist-ssr
coverage
*.tsbuildinfo

# OS
.DS_Store

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.eslintcache

# Cypress / Vitest
/cypress/videos/
/cypress/screenshots/
__screenshots__/

# Freeze Artifacts
!freeze/**/*.log

# Environment variables（秘密情報を含むため絶対にコミットしない）
.env
.env.local
.env*.local
.env.production
*.local

# Sensitive data（秘密鍵・認証情報）
service-account-key.json
service-account*.json
serviceAccount*.json
*-private-key.json
**/certs/*.json
*.pem
*.key
*.p12
*.pfx

# JSON（データファイル除外、設定ファイルは許可）
*.json
!package.json
!package-lock.json
!tsconfig.json
!tsconfig.*.json
!.eslintrc.cjs

# 一時ファイル（docs配下の監査記録txtは許可）
*.txt
!docs/**/*.txt

# ggshield
.cache_ggshield

# データディレクトリ（実行時データ。トップレベルのdata/内のみ除外）
# ※gitはディレクトリ除外後の否定パターンが効かないため、個別パターンで除外する
/data/**
!/data/.gitkeep
!/data/README.md
analysis/

# テスト関連
src/scripts/test_images/
src/scripts/test_results/

# AI生成物
.gemini_artifacts/

# Local History (VSCode)
.history/

# Python cache
__pycache__/
*.pyc

# アーカイブ済みドキュメント
docs/_archive_legacy/
