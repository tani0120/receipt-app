{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.scripts.tsbuildinfo",
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "skipLibCheck": true
  },
  "include": [
    "env.d.ts",
    "src/scripts/**/*",
    "src/shared/**/*",
    "src/domain/**/*",
    "src/core/**/*",
    "src/repositories/**/*",
    "src/services/firestoreRepository.ts",
    "src/types/**/*",
    "src/mocks/types/pipeline/**/*",
    "src/firebase.ts"
  ]
}
